# CRM Agents — backend environment variables
#
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to git — only this `.env.example` template.

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Async driver (asyncpg) required.
DATABASE_URL=postgresql+asyncpg://user@localhost:5432/crm_agents
# Set to true only when debugging SQL queries — VERY verbose
DATABASE_ECHO=false

# ─── App ──────────────────────────────────────────────────────────────────────
# Set to false in production. When false, the app fails to start if any
# security-critical secret (JWT_SECRET_KEY, VAULT_ENCRYPTION_KEY) is missing.
DEBUG=true

# Comma/JSON list of allowed CORS origins (the frontend dev server, prod domain, etc.)
CORS_ORIGINS=["http://localhost:5173"]

# ─── Auth — JWT signing key ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# REQUIRED in production (DEBUG=false). Without it, the app fails to start.
JWT_SECRET_KEY=

# ─── Vault — credential encryption key (Fernet) ───────────────────────────────
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# REQUIRED in production (DEBUG=false). Without it, credentials cannot be
# encrypted/decrypted and the app fails to start.
#
# IMPORTANT: back this up separately from the database. If you lose this key,
# ALL stored credentials become permanently unreadable.
VAULT_ENCRYPTION_KEY=

# ─── LLM provider ─────────────────────────────────────────────────────────────
# Anthropic Claude API key. Used by the agent execution engine for internal agents.
# When the system runs in "LLM local" mode (Cloud Dedicada tier — Phase 5),
# this becomes optional.
ANTHROPIC_API_KEY=
